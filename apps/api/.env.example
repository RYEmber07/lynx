# ==========================================
# Application Configuration
# ==========================================
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ==========================================
# Database & Cache
# ==========================================
# Postgres connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/lynx
# Redis connection string
REDIS_URL=redis://localhost:6379

# ==========================================
# Authentication (JWT)
# ==========================================
# Secrets must be at least 32 characters long
JWT_ACCESS_SECRET=your-super-secret-jwt-key-minimum-32-chars-long!!
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-chars!!

# Token expiration times
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Caching
CACHE_TTL_SECONDS=3600