# ---------------------------------------
# Stage 1: Dependencies
# ---------------------------------------
FROM node:20-alpine AS deps
WORKDIR /app

# Copy package files
COPY package*.json ./

# Upgrade npm to match your lockfile
RUN npm install -g npm@11

# Install ALL dependencies
RUN npm ci

# ---------------------------------------
# Stage 2: Builder
# ---------------------------------------
FROM node:20-alpine AS builder
WORKDIR /app

# Copy the installed node_modules from the deps stage
COPY --from=deps /app/node_modules ./node_modules

# Copy your actual Next.js source code
COPY . .

# IMPORTANT NEXT.JS : Build-time Environment Variables
# Next.js "bakes" any NEXT_PUBLIC_ variables directly into the static HTML 
# when it compiles. It CANNOT read them at runtime! We must pass them as ARGs.
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

# Compile the Next.js app
RUN npm run build

# ---------------------------------------
# Stage 3: Production
# ---------------------------------------
FROM node:20-alpine AS production
WORKDIR /app

ENV NODE_ENV=production

# Security: Run as non-root user
RUN addgroup -S lynx && adduser -S lynx -G lynx

# Next.js standalone mode generates a tiny, self-contained server.
# But it intentionally excludes static assets (assuming you use a CDN).
# We must manually copy the public and static folders to serve them ourselves!
COPY --from=builder /app/public ./public
COPY --from=builder --chown=lynx:lynx /app/.next/standalone ./
COPY --from=builder --chown=lynx:lynx /app/.next/static ./.next/static

USER lynx

EXPOSE 3000

# server.js is automatically generated by Next.js standalone output
CMD ["node", "server.js"]
