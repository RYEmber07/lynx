# Prevents sensitive files and build artifacts from being 
# sent to the Docker build context. Smaller context = faster builds.

# Dependencies
**/node_modules

# Git
.git
.gitignore

# Environment variables
# SECURITY: Never bake .env files into your permanent Docker Images!
# If an image is uploaded to a registry, anyone could extract your passwords.
# Because these are ignored during 'COPY . .', you MUST pass required build-time
# variables (like NEXT_PUBLIC_API_URL) via 'args:' in docker-compose.prod.yml.
# NOTE: Local Dev (docker-compose.yml) uses Volume Bind Mounts which bypass 
# this ignore file, allowing the dev server to see the .env.local file directly.
**/.env
**/.env.local
**/.env.*.local
**/.env.production
**/.env.example

# Build outputs
**/dist
**/.next
**/src/generated

# Logs
**/*.log

# Docker/OS
docker-compose*.yml
**/Dockerfile
.DS_Store

# Testing & Docs
**/*.test.ts
**/*.spec.ts
**/*.md
.notes/

# IDE
.vscode/